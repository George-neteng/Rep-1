[Unit]
Description=Football Ball Analysis (YOLOv8 + Flask)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/football-app
Environment="YOLO_MODEL=yolov8n.pt"
Environment="YOLO_CONF=0.25"
# 1 воркер: модель грузится в память на каждый воркер. timeout — под видео.
ExecStart=/opt/football-app/venv/bin/gunicorn -w 1 -b 127.0.0.1:8000 --timeout 600 app:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
